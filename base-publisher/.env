################################################
#                                                   
#     🚨🚨🚨  WARNING: PUBLIC .ENV  🚨🚨🚨      
#                                         
################################################
RUST_LOG=info

DATABASE_URL=postgres://postgres:password@localhost:5432/api_document
PG_MAX_CONNECTIONS=10
PG_ACQUIRE_TIMEOUT_SECS=30

PULSAR_URL=pulsar://localhost:6650
PULSAR_RECONNECT_DELAY_SECS=5
PULSAR_MAX_RETRIES=10
PULSAR_BATCH_SIZE=100


TOPIC_LIST=persistent://public/default/api-document.folder,persistent://public/default/api-document.document

BATCH_SIZE=50

POLL_INTERVAL=5